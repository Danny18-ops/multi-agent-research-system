# ╔══════════════════════════════════════════════════════════════════════╗
# ║        Multi-Agent Research System — Environment Variables          ║
# ╚══════════════════════════════════════════════════════════════════════╝
#
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#
# NEVER commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# OpenAI API key (required — https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# ── LLM Settings ──────────────────────────────────────────────────────────────

# Primary model name (used by all agents — MODEL_NAME takes precedence over OPENAI_MODEL)
# Options: gpt-4o | gpt-4o-mini | gpt-4-turbo | gpt-3.5-turbo
MODEL_NAME=gpt-4o

# Legacy alias — keep in sync with MODEL_NAME
OPENAI_MODEL=gpt-4o

# Creativity / randomness (0.0 = deterministic, 1.0 = creative)
OPENAI_TEMPERATURE=0.1

# ── Search APIs (at least one recommended) ────────────────────────────────────

# Serper — fast, affordable Google Search API (https://serper.dev)
# Leave blank to fall back to free DuckDuckGo backend
SERPER_API_KEY=your-serper-api-key-here

# Tavily AI search — LLM-optimised results (https://tavily.com)
TAVILY_API_KEY=tvly-...

# SerpAPI — alternative Google search backend (https://serpapi.com)
SERPAPI_API_KEY=

# ── Agent Behaviour ───────────────────────────────────────────────────────────

# Maximum reasoning steps per agent before it stops
MAX_ITERATIONS=10

# Maximum retry attempts on failed tool calls
MAX_RETRIES=3

# HTTP request timeout in seconds
REQUEST_TIMEOUT=60

# Maximum web search results to retrieve per query
MAX_SEARCH_RESULTS=5

# ── Quality Control ───────────────────────────────────────────────────────────

# Minimum acceptable quality score (0.0–1.0); below this triggers a revision
MIN_QUALITY_SCORE=0.7

# ── Output & Logging ──────────────────────────────────────────────────────────

# Directory where research reports are saved
OUTPUT_DIR=outputs

# Directory where log files are written
LOG_DIR=logs

# Log verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
