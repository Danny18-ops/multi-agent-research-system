.mypy_cache/
.ruff_cache/

# ── Build & distribution ───────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ── Generated outputs & logs ───────────────────────────────────────────────────
outputs/
logs/

# ── IDE & OS artefacts ────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
*.swo
Thumbs.db
.claude
